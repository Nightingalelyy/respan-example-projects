# Required: your Respan (Keywords AI) API key
RESPAN_API_KEY=your_respan_api_key_here

# Required for non-gateway examples (direct Anthropic):
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override the Respan base URL (default: https://api.keywordsai.co/api)
# RESPAN_BASE_URL=https://api.keywordsai.co/api

# For gateway examples (routes through Respan, no Anthropic key needed):
# RESPAN_GATEWAY_BASE_URL=https://api.keywordsai.co/api
