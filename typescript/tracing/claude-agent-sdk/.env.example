# Required: your Respan API key.
# Used for both Respan tracing and the Anthropic-compatible gateway.
RESPAN_API_KEY=your_respan_api_key_here

# Optional: use a dedicated gateway key name instead of RESPAN_API_KEY.
# RESPAN_GATEWAY_API_KEY=your_respan_api_key_here

# Optional: override the Respan base URL.
# RESPAN_BASE_URL=https://api.respan.ai/api

# Optional: override the Claude Agent SDK model alias.
# CLAUDE_AGENT_MODEL=sonnet
