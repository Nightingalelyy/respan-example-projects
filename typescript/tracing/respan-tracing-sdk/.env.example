# Respan Tracing SDK Configuration
# Copy this file to .env and fill in your actual API keys

# Respan API Configuration
# Get your API key from: https://platform.respan.ai/platform/api-keys
RESPAN_API_KEY=your_respan_api_key
RESPAN_BASE_URL=https://api.respan.ai

# OpenAI API Configuration (optional, for OpenAI examples)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API Configuration (optional, for Anthropic examples)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Note: When using Respan as an LLM Gateway for tracing,
# you can use your Respan API key for OpenAI calls:
# OPENAI_API_KEY=your_respan_api_key
# OPENAI_BASE_URL=https://api.respan.ai/api
