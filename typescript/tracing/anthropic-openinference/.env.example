# Required: your Respan API key
RESPAN_API_KEY=your_respan_api_key_here

# Optional: gateway-specific aliases
# RESPAN_GATEWAY_API_KEY=your_respan_api_key_here
# RESPAN_GATEWAY_BASE_URL=https://api.respan.ai/api

# Optional: override the Anthropic model used by the example
# ANTHROPIC_MODEL=claude-haiku-4-5
