{
  "name": "anthropic-openinference-typescript-example",
  "version": "0.1.0",
  "description": "Anthropic OpenInference example for Respan tracing",
  "type": "module",
  "scripts": {
    "postinstall": "tsc -p node_modules/@respan/respan-sdk/tsconfig.json && tsc -p node_modules/@respan/tracing/tsconfig.json && tsc -p node_modules/@respan/instrumentation-openinference/tsconfig.json",
    "example": "tsx anthropic_openinference_example.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@arizeai/openinference-instrumentation-anthropic": "^0.1.7",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@respan/instrumentation-openinference": "file:../../../../respan/javascript-sdks/respan-instrumentation-openinference",
    "@respan/respan-sdk": "file:../../../../respan/javascript-sdks/respan-sdk",
    "@respan/tracing": "file:../../../../respan/javascript-sdks/respan-tracing",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.20.3",
    "typescript": "^5.7.0"
  }
